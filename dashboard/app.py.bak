        "t.reasoning, t.executed_at "
        "FROM trades t JOIN ai_players p ON t.player_id = p.id "
        "ORDER BY t.executed_at DESC LIMIT ?", (limit,)
    ).fetchall()
    conn.close()
    return [dict(t) for t in trades]


