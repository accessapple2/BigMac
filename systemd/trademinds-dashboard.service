[Unit]
Description=OllieTrades Dashboard — FastAPI trader UI + scheduler (main.py on :8080)
Documentation=file:///home/bigmac/autonomous-trader/systemd/README.md
After=network-online.target ollama.service
Wants=network-online.target ollama.service

[Service]
Type=simple
User=bigmac
Group=bigmac
WorkingDirectory=/home/bigmac/autonomous-trader

EnvironmentFile=/home/bigmac/autonomous-trader/.env
Environment=PATH=/usr/local/bin:/usr/bin:/bin

ExecStart=/home/bigmac/autonomous-trader/venv/bin/python3 main.py

Restart=on-failure
RestartSec=10

# Journal handles stdout/stderr by default.
# Follow live: journalctl -u trademinds-dashboard -f

[Install]
WantedBy=multi-user.target
